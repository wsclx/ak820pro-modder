{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AK820 Pro",
  "version": "0.1.0",
  "identifier": "com.mariolohe.ak820pro",
  "build": {
    "beforeDevCommand": "pnpm build",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AK820 Pro",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Control software for the Epomaker / Ajazz AK820 Pro",
    "longDescription": "Open-source, macOS-first configuration tool for the Epomaker / Ajazz AK820 Pro keyboard. Lighting, keymap, macros, TFT display, and more.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
