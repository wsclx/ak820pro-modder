{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AK820 Pro Modder",
  "version": "0.7.0-beta",
  "identifier": "io.github.wsclx.ak820pro-modder",
  "build": {
    "beforeDevCommand": "pnpm build",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AK820 Pro Modder",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "Open-source control software for the Epomaker / Ajazz AK820 Pro keyboard",
    "longDescription": "AK820 Pro Modder is a clean, macOS-first replacement for the official Windows-only Epomaker / Ajazz tool. Manage lighting, remap any key, record macros, paint per-key RGB, and upload TFT animations — all via a native Tauri shell over a reverse-engineered HID protocol.",
    "publisher": "wsclx",
    "copyright": "Copyright (c) 2026 wsclx. Licensed under MIT.",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
